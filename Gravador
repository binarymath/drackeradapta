<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gravador de Áudio Pro</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome para ícones -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Animação suave para o botão de gravar */
        @keyframes pulse-ring {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }
        .recording-pulse {
            animation: pulse-ring 2s infinite;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1f2937; 
        }
        ::-webkit-scrollbar-thumb {
            background: #4b5563; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #6b7280; 
        }
    </style>
</head>
<body class="bg-gray-900 text-white min-h-screen flex flex-col items-center justify-center p-4 font-sans selection:bg-red-500 selection:text-white">

    <div class="w-full max-w-md bg-gray-800 rounded-2xl shadow-2xl overflow-hidden border border-gray-700">
        
        <!-- Header -->
        <div class="p-6 bg-gray-800 border-b border-gray-700 flex justify-between items-center">
            <h1 class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-microphone-lines text-red-500"></i>
                Gravador de Voz
            </h1>
            <span id="statusText" class="text-xs font-mono text-gray-400 px-2 py-1 rounded bg-gray-700">Pronto</span>
        </div>

        <!-- Visualizer Area -->
        <div class="relative h-48 bg-gray-900 flex items-center justify-center overflow-hidden">
            <canvas id="visualizer" class="w-full h-full absolute inset-0 z-10"></canvas>
            
            <!-- Timer Display (Overlay) -->
            <div class="z-20 text-center">
                <div id="timer" class="text-5xl font-mono font-bold tracking-wider text-gray-200 drop-shadow-lg">00:00</div>
                <p class="text-gray-500 text-sm mt-1">Duração</p>
            </div>
        </div>

        <!-- Controls -->
        <div class="p-8 flex justify-center gap-6 bg-gray-800">
            <!-- Botão Gravar -->
            <button id="recordBtn" class="group relative w-16 h-16 rounded-full bg-gray-700 hover:bg-gray-600 transition-all duration-300 flex items-center justify-center outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                <div id="recordIcon" class="w-6 h-6 rounded-full bg-red-500 group-hover:scale-110 transition-transform duration-200"></div>
                <i id="stopIcon" class="fas fa-square text-white text-xl hidden"></i>
            </button>
        </div>

        <!-- Error Message Container -->
        <div id="errorMessage" class="hidden mx-4 mb-4 p-3 bg-red-900/50 border border-red-500 rounded text-sm text-red-200 text-center">
        </div>

        <!-- Recordings List -->
        <div class="bg-gray-850 border-t border-gray-700">
            <div class="px-6 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-800/50">
                As suas gravações
            </div>
            <div id="recordingsList" class="max-h-60 overflow-y-auto p-2 space-y-2">
                <!-- Empty State -->
                <div id="emptyState" class="text-center py-8 text-gray-500 text-sm">
                    <i class="fas fa-inbox text-2xl mb-2 block opacity-50"></i>
                    Ainda sem gravações.
                </div>
            </div>
        </div>
    </div>

    <script>
        // Elementos do DOM
        const recordBtn = document.getElementById('recordBtn');
        const recordIcon = document.getElementById('recordIcon');
        const stopIcon = document.getElementById('stopIcon');
        const timerDisplay = document.getElementById('timer');
        const canvas = document.getElementById('visualizer');
        const recordingsList = document.getElementById('recordingsList');
        const emptyState = document.getElementById('emptyState');
        const statusText = document.getElementById('statusText');
        const errorMessage = document.getElementById('errorMessage');

        // Variáveis de Estado e Áudio
        let mediaRecorder;
        let isRecording = false;
        let startTime;
        let timerInterval;
        let audioContext;
        let analyser;
        let dataArray;
        let source;
        let animationId;

        // Configuração do Canvas
        const canvasCtx = canvas.getContext('2d');
        
        // Redimensionar canvas para alta resolução
        function resizeCanvas() {
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        // Inicializar Visualizador (Onda Sonora)
        function initVisualizer(stream) {
            if (!audioContext) {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
            }
            
            analyser = audioContext.createAnalyser();
            source = audioContext.createMediaStreamSource(stream);
            source.connect(analyser);
            
            // Configurar FFT (Fast Fourier Transform)
            analyser.fftSize = 256;
            const bufferLength = analyser.frequencyBinCount;
            dataArray = new Uint8Array(bufferLength);
            
            drawVisualizer();
        }

        function drawVisualizer() {
            if (!isRecording) {
                // Desenhar linha plana se parado
                canvasCtx.clearRect(0, 0, canvas.width, canvas.height);
                canvasCtx.fillStyle = '#111827'; // bg-gray-900
                canvasCtx.fillRect(0, 0, canvas.width, canvas.height);
                
                canvasCtx.lineWidth = 2;
                canvasCtx.strokeStyle = '#374151'; // cinzento escuro
                canvasCtx.beginPath();
                canvasCtx.moveTo(0, canvas.height / 2);
                canvasCtx.lineTo(canvas.width, canvas.height / 2);
                canvasCtx.stroke();
                return;
            }

            animationId = requestAnimationFrame(drawVisualizer);
            analyser.getByteFrequencyData(dataArray);

            canvasCtx.fillStyle = '#111827';
            canvasCtx.fillRect(0, 0, canvas.width, canvas.height);

            const barWidth = (canvas.width / dataArray.length) * 2.5;
            let barHeight;
            let x = 0;

            for (let i = 0; i < dataArray.length; i++) {
                barHeight = dataArray[i] / 1.5; // Ajustar escala

                // Criar gradiente para as barras
                const gradient = canvasCtx.createLinearGradient(0, canvas.height - barHeight, 0, canvas.height);
                gradient.addColorStop(0, '#ef4444'); // Vermelho topo
                gradient.addColorStop(1, '#7f1d1d'); // Vermelho escuro base

                canvasCtx.fillStyle = gradient;
                
                // Desenhar barras espelhadas a partir do centro verticalmente
                const y = (canvas.height - barHeight) / 2;
                
                // Arredondar cantos das barras
                canvasCtx.fillRect(x, y, barWidth, barHeight);

                x += barWidth + 1;
            }
        }

        // Lógica do Temporizador
        function startTimer() {
            startTime = Date.now();
            timerInterval = setInterval(() => {
                const elapsedTime = Date.now() - startTime;
                const date = new Date(elapsedTime);
                const minutes = date.getUTCMinutes().toString().padStart(2, '0');
                const seconds = date.getUTCSeconds().toString().padStart(2, '0');
                timerDisplay.textContent = `${minutes}:${seconds}`;
            }, 1000);
        }

        function stopTimer() {
            clearInterval(timerInterval);
            timerDisplay.textContent = '00:00';
        }

        // Lógica de Gravação
        async function toggleRecording() {
            if (!isRecording) {
                // Iniciar Gravação
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    
                    mediaRecorder = new MediaRecorder(stream);
                    // Variável local para isolar os dados desta gravação específica
                    let currentChunks = [];

                    mediaRecorder.ondataavailable = (event) => {
                        if (event.data.size > 0) {
                            currentChunks.push(event.data);
                        }
                    };

                    mediaRecorder.onstop = () => {
                        const audioBlob = new Blob(currentChunks, { type: 'audio/webm' });
                        const audioUrl = URL.createObjectURL(audioBlob);
                        addRecordingToList(audioUrl, audioBlob.size);
                        
                        // Parar todas as tracks do stream para libertar o microfone
                        stream.getTracks().forEach(track => track.stop());
                    };

                    mediaRecorder.start();
                    initVisualizer(stream);
                    startTimer();
                    
                    // Atualizar UI
                    isRecording = true;
                    recordBtn.classList.add('recording-pulse', 'bg-red-500/10');
                    recordIcon.classList.add('hidden');
                    stopIcon.classList.remove('hidden');
                    statusText.textContent = "A gravar...";
                    statusText.classList.replace('text-gray-400', 'text-red-400');
                    statusText.classList.replace('bg-gray-700', 'bg-red-900/30');
                    errorMessage.classList.add('hidden');

                } catch (err) {
                    console.error("Erro ao aceder ao microfone:", err);
                    errorMessage.textContent = "Erro: Acesso ao microfone negado. Por favor permita o acesso para gravar.";
                    errorMessage.classList.remove('hidden');
                }
            } else {
                // Parar Gravação
                mediaRecorder.stop();
                stopTimer();
                cancelAnimationFrame(animationId);
                
                // Atualizar UI
                isRecording = false;
                recordBtn.classList.remove('recording-pulse', 'bg-red-500/10');
                recordIcon.classList.remove('hidden');
                stopIcon.classList.add('hidden');
                statusText.textContent = "Pronto";
                statusText.classList.replace('text-red-400', 'text-gray-400');
                statusText.classList.replace('bg-red-900/30', 'bg-gray-700');
                
                // Limpar canvas
                drawVisualizer(); 
            }
        }

        // Adicionar gravação à lista
        function addRecordingToList(url, size) {
            emptyState.style.display = 'none';
            
            const date = new Date();
            const timeStr = date.toLocaleTimeString('pt-PT', { hour: '2-digit', minute: '2-digit' });
            const name = `Gravação ${timeStr}`;
            const sizeStr = (size / 1024).toFixed(1) + ' KB';

            const item = document.createElement('div');
            item.className = "group flex items-center justify-between p-3 bg-gray-800 hover:bg-gray-700 rounded-lg transition-colors border border-gray-700 hover:border-gray-600 animate-[fadeIn_0.3s_ease-out]";
            
            item.innerHTML = `
                <div class="flex items-center gap-3 overflow-hidden">
                    <div class="w-8 h-8 rounded-full bg-gray-900 flex items-center justify-center text-red-500">
                        <i class="fas fa-play text-xs play-icon cursor-pointer"></i>
                        <i class="fas fa-pause text-xs pause-icon hidden cursor-pointer"></i>
                    </div>
                    <div class="flex flex-col min-w-0">
                        <span class="text-sm font-medium text-gray-200 truncate">${name}</span>
                        <span class="text-xs text-gray-500">${sizeStr}</span>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a href="${url}" download="gravacao_${Date.now()}.webm" class="p-2 text-gray-400 hover:text-white transition-colors" title="Download">
                        <i class="fas fa-download"></i>
                    </a>
                    <button class="delete-btn p-2 text-gray-400 hover:text-red-500 transition-colors" title="Apagar">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
                <audio src="${url}" class="hidden"></audio>
            `;

            // Lógica de Play/Pause dentro do item
            const audio = item.querySelector('audio');
            const playIcon = item.querySelector('.play-icon');
            const pauseIcon = item.querySelector('.pause-icon');
            const btnContainer = item.querySelector('.w-8');
            const deleteBtn = item.querySelector('.delete-btn');

            // Toggle Play
            btnContainer.addEventListener('click', () => {
                // Parar todos os outros áudios
                document.querySelectorAll('audio').forEach(a => {
                    if(a !== audio) {
                        a.pause();
                        a.currentTime = 0;
                    }
                });
                document.querySelectorAll('.play-icon').forEach(i => i.classList.remove('hidden'));
                document.querySelectorAll('.pause-icon').forEach(i => i.classList.add('hidden'));

                if (audio.paused) {
                    audio.play();
                    playIcon.classList.add('hidden');
                    pauseIcon.classList.remove('hidden');
                } else {
                    audio.pause();
                    playIcon.classList.remove('hidden');
                    pauseIcon.classList.add('hidden');
                }
            });

            audio.onended = () => {
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
            };

            // Delete
            deleteBtn.addEventListener('click', () => {
                item.remove();
                if (recordingsList.children.length <= 1) { // 1 porque o emptyState conta como filho
                    emptyState.style.display = 'block';
                }
            });

            recordingsList.insertBefore(item, recordingsList.firstChild.nextSibling); // Inserir no topo (abaixo do empty state)
        }

        // Event Listeners
        recordBtn.addEventListener('click', toggleRecording);

        // Inicializar o canvas limpo
        drawVisualizer();

    </script>
</body>
</html>