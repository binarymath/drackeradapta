// --- FUNÇÕES UTILITÁRIAS ---
const getRandom = (arr) => arr[Math.floor(Math.random() * arr.length)];

const getStoryElements = (theme) => {
  const lowerTheme = theme.toLowerCase();
  let type = 'default';

  for (const [key, keywords] of Object.entries(SUBJECT_KEYWORDS)) {
    if (keywords.some(k => lowerTheme.includes(k))) {
      type = key;
      break;
    }
  }

  const archetype = STORY_ARCHETYPES[type] || STORY_ARCHETYPES.default;
  
  return {
    villain: getRandom(archetype.villains),
    minion: getRandom(archetype.minions),
    setting: getRandom(archetype.settings),
    plot: getRandom(archetype.plots),
    intro: getRandom(archetype.intros),
    type: type
  };
};

