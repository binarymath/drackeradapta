          { id: 3, title: s3.title, enemy: "Enigma Antigo", desc: s3.desc(elements.setting, elements.villain, elements.minion), question: questions.q3, difficulty: "Médio" },
          { id: 4, title: s4.title, enemy: "Ilusão das Sombras", desc: s4.desc(elements.setting, elements.villain, elements.minion), question: questions.q4, difficulty: "Difícil" },
          { id: 5, title: s5.title, enemy: elements.villain, desc: s5.desc(elements.setting, elements.villain, elements.minion), question: questions.q5, difficulty: "Chefe" }
        ]
      };
      setAdventureData(newAdventure);
      setIsGenerating(false);
      setView('adventure');
    }, 1500);
  };

  const saveEdit = (idx) => {
    const newEncounters = [...adventureData.encounters];
    newEncounters[idx].question = editTemp;
    setAdventureData({ ...adventureData, encounters: newEncounters });
    setEditingId(null);
  };

  return (
    <div className="min-h-screen bg-stone-100 font-sans text-stone-800 pb-12">
      <div className="max-w-5xl mx-auto p-4 md:p-8">
        
        <header className="text-center mb-8 print:hidden">
          <DrackerAvatar />
          <h1 className="text-3xl font-bold text-amber-900">Drácker RPG: Aventura & Conhecimento</h1>
        </header>

        {view === 'setup' && (
          <div className="bg-white rounded-2xl shadow-xl p-8 max-w-2xl mx-auto border-t-8 border-amber-500 animate-fade-in">
            <h2 className="text-2xl font-bold text-stone-800 mb-6 text-center">Início da Aventura</h2>
            <div className="space-y-4">
              <input 
                type="text" 
                value={theme}
                onChange={(e) => setTheme(e.target.value)}
                placeholder="Ex: Frações, Verbos, Egito..."
                className="w-full p-4 text-lg border-2 border-stone-200 rounded-xl focus:border-amber-500 outline-none"
                onKeyDown={(e) => e.key === 'Enter' && generateAdventure()}
              />
              <button onClick={generateAdventure} disabled={!theme || isGenerating} className="w-full py-4 rounded-xl font-bold text-white text-lg bg-green-600 hover:bg-green-700 flex justify-center items-center gap-2 shadow-md">
                {isGenerating ? <RefreshCw className="animate-spin"/> : <Sparkles />} 
                {isGenerating ? "Criando História Única..." : "Gerar Aventura Aleatória"}
              </button>
              <div className="pt-4 text-center grid grid-cols-2 gap-4">
                 <button onClick={() => setView('management')} className="text-blue-600 font-bold hover:underline flex items-center justify-center gap-2 border border-blue-100 rounded py-2"><Users size={16}/> Organizar Sala</button>
                 <button onClick={() => setView('rules')} className="text-amber-600 font-bold hover:underline flex items-center justify-center gap-2 border border-amber-100 rounded py-2"><Book size={16}/> Ver Regras</button>
              </div>
            </div>
          </div>
        )}

        {view === 'adventure' && adventureData && (
          <div className="space-y-6 animate-fade-in">
            <div className="flex justify-between bg-stone-200 p-2 rounded-lg print:hidden">
              <button onClick={() => setView('setup')} className="px-4 py-2 text-stone-600 font-bold text-sm">← Novo</button>
              <div className="flex gap-2">
                <button onClick={() => setView('rules')} className="px-4 py-2 bg-amber-500 text-white rounded font-bold text-sm flex gap-2 hover:bg-amber-600 items-center"><Book size={16}/> Regras de XP</button>
                <button onClick={() => setView('management')} className="px-4 py-2 bg-blue-600 text-white rounded font-bold text-sm flex gap-2 hover:bg-blue-700 items-center"><Users size={16}/> Guildas</button>
              </div>
            </div>

            <div className="bg-white rounded-xl shadow-lg border border-stone-200">
              <div className="bg-stone-800 text-amber-400 p-6 flex justify-between items-center print:bg-white print:text-black print:border-b-2 print:border-black">
                <div>
                  <h2 className="text-3xl font-bold">{adventureData.title}</h2>
                  <p className="text-sm mt-1 opacity-80 flex items-center gap-2 print:text-black"><Clock size={14}/> 50 Minutos • 5 Capítulos</p>
                </div>
                <button onClick={() => window.print()} className="print:hidden bg-stone-700 p-2 rounded hover:bg-stone-600"><Book/></button>
              </div>

              <div className="p-6 space-y-6">
                <div className="flex gap-4 mb-6 bg-amber-50 p-4 rounded-lg border border-amber-100 print:bg-white print:border-black">
                  <MessageCircle className="text-amber-600 shrink-0 mt-1 print:text-black"/>
                  <div>
                    <span className="text-xs font-bold text-amber-800 uppercase print:text-black">O Chamado</span>
                    <p className="italic text-stone-700 text-sm print:text-black">"{adventureData.intro} O culpado é <strong>{adventureData.villain}</strong>! Ele {adventureData.plot}."</p>
                  </div>
                </div>

                <div className="relative border-l-2 border-stone-200 ml-4 space-y-8 pb-4 print:border-l-0 print:ml-0">
                  {adventureData.encounters.map((enc, idx) => (
                    <div key={idx} className="relative pl-8 print:pl-0 print:mb-4">
                      <div className={`absolute -left-[17px] top-0 w-9 h-9 rounded-full flex items-center justify-center font-bold border-4 z-10 print:hidden ${idx === 4 ? 'bg-red-500 text-white border-white' : 'bg-white text-stone-500 border-stone-200'}`}>{idx + 1}</div>
                      <div className={`border rounded-lg p-5 shadow-sm print:border-black print:bg-white ${idx === 4 ? 'bg-red-50 border-red-200' : 'bg-white border-stone-200'}`}>
                        <div className="flex justify-between items-start mb-2">
                          <h3 className={`font-bold text-lg flex items-center gap-2 ${idx === 4 ? 'text-red-900' : 'text-stone-800'} print:text-black`}>
                            {idx === 4 ? <Skull size={18}/> : <MapPin size={18}/>} {enc.title}
                          </h3>
                          <span className="text-xs font-bold uppercase px-2 py-1 rounded bg-stone-100 text-stone-500 print:border print:border-black print:text-black">{enc.difficulty}</span>
                        </div>
                        <p className="text-sm text-stone-600 mb-3 italic print:text-black">{enc.desc}</p>
                        <div className={`p-4 rounded-lg border relative ${idx === 4 ? 'bg-white border-red-100' : 'bg-stone-50 border-stone-200'} print:bg-white print:border-black`}>
                           <span className="absolute -top-2.5 left-3 bg-white px-2 text-[10px] font-bold uppercase text-stone-400 border rounded print:text-black print:border-black">Pergunta do Mestre</span>
                           {editingId === enc.id ? (
                             <div className="flex gap-2 mt-1">
                               <textarea value={editTemp} onChange={(e) => setEditTemp(e.target.value)} className="w-full p-2 border rounded text-sm" rows={2}/>
                               <button onClick={() => saveEdit(idx)} className="bg-blue-600 text-white px-3 rounded text-xs font-bold"><Save size={14}/> Salvar</button>
                             </div>
                           ) : (
                             <>
                               <p className="font-medium text-stone-900 mt-1 print:text-black">"{enc.question}"</p>
                               <button onClick={() => { setEditingId(enc.id); setEditTemp(enc.question); }} className="absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-stone-400 hover:text-blue-600 print:hidden"><Edit3 size={16}/></button>
                             </>
                           )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        )}

        {view === 'rules' && <RulesScreen onBack={() => setView(adventureData ? 'adventure' : 'setup')} />}
        {view === 'management' && <ManagementScreen onBack={() => setView(adventureData ? 'adventure' : 'setup')} />}
      </div>
      <style>{`
        @media print {
          body { background: white; color: black; }
          button, .print\\:hidden { display: none !important; }
          .shadow-xl, .shadow-lg, .shadow-md { box-shadow: none !important; }
        }
        @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fade-in 0.3s ease-out forwards; }
      `}</style>
    </div>
  );
}