  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState('');
  
  // Estado para áudio
  const [isSpeaking, setIsSpeaking] = useState(false);
  const [isGeneratingAudio, setIsGeneratingAudio] = useState(false);
  const audioRef = useRef(null);

  const activityOptions = [
    { id: 'quiz', label: 'Quiz / Perguntas', icon: '❓' },
    { id: 'wordsearch', label: 'Caça-Palavras', icon: 'abcd' },
    { id: 'social_story', label: 'História Social', icon: '📖' },
    { id: 'simplify', label: 'Simplificar Texto', icon: '📉' },
    { id: 'true_false', label: 'Verdadeiro ou Falso', icon: '✅' },
    { id: 'match', label: 'Ligar Colunas / Relacionar', icon: '↔️' },
    { id: 'fill_blanks', label: 'Completar Lacunas', icon: '📝' },
  ];

  const difficultyOptions = [
    { id: 'easy', label: 'Fácil', desc: 'Curto, simples' },
    { id: 'medium', label: 'Médio', desc: 'Padrão' },
    { id: 'hard', label: 'Difícil', desc: 'Detalhado, complexo' },
  ];

  useEffect(() => {
    return () => {
      if (audioRef.current) {
        audioRef.current.pause();
        audioRef.current = null;
      }
    };
  }, []);

  const fetchGemini = async (model, payload, retryCount = 0) => {
    const delay = Math.pow(2, retryCount) * 1000;
    
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (response.status === 503 || response.status === 429) {
        throw new Error('Overloaded');
      }

      const data = await response.json();
      
      if (data.error) {
         if (data.error.message && data.error.message.toLowerCase().includes('overloaded')) {
             throw new Error('Overloaded');
         }
         throw new Error(data.error.message);
      }
      
      return data;
      
    } catch (error) {
      if ((error.message === 'Overloaded' || error.message.toLowerCase().includes('overloaded')) && retryCount < 5) {
        console.log(`Modelo sobrecarregado. Tentativa ${retryCount + 1} em ${delay}ms...`);
        await new Promise(resolve => setTimeout(resolve, delay));
        return fetchGemini(model, payload, retryCount + 1);
      }
      throw error;
    }
  };

  const handleSpeak = async () => {
    if (isSpeaking && audioRef.current) {
      audioRef.current.pause();
      setIsSpeaking(false);
      return;
    }

    if (!generatedContent || !apiKey) {
      if (!apiKey) setShowSettings(true);
      return;
    }

    setIsGeneratingAudio(true);
    setError('');

    const cleanText = generatedContent
      .replace(/\*\*/g, '')
      .replace(/##/g, '')
      .replace(/###/g, '')
      .replace(/`/g, '')
      .replace(/^[*-] /gm, '')
      .replace(/\|/g, ' ') // Remove barras de tabela para leitura
      .replace(/A B C D E.*/s, '') 
      .trim();

    const textToSpeak = cleanText.substring(0, 1000); 

    try {
      const data = await fetchGemini('gemini-2.5-flash-preview-tts', {
        contents: [{ parts: [{ text: textToSpeak }] }],
        generationConfig: {
          responseModalities: ["AUDIO"],
          speechConfig: {
            voiceConfig: {
              prebuiltVoiceConfig: {
                voiceName: "Aoede"
              }
            }
          }
        }
      });

      const audioData = data.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
      
      if (!audioData) {
        throw new Error('Nenhum áudio recebido da IA.');
      }

      const wavUrl = pcmToWav(audioData, 24000);
      
      if (audioRef.current) audioRef.current.pause();
      
      const audio = new Audio(wavUrl);
      audioRef.current = audio;
      
      audio.onended = () => setIsSpeaking(false);
      audio.onpause = () => setIsSpeaking(false);
      audio.onerror = () => {
        setIsSpeaking(false);
        setError('Erro ao reproduzir áudio.');
      };

      await audio.play();
      setIsSpeaking(true);

    } catch (err) {
      console.error(err);
      setError(`Erro no áudio neural: ${err.message}. Tentando voz padrão...`);
      
      const fallbackUtterance = new SpeechSynthesisUtterance(cleanText);
      fallbackUtterance.lang = 'pt-BR';
      window.speechSynthesis.speak(fallbackUtterance);
    } finally {
      setIsGeneratingAudio(false);
    }
  };

  const handleGenerate = async () => {
    if (!apiKey) {
      setError('Por favor, insira sua chave API nas configurações.');
      setShowSettings(true);
      return;
    }
    if (!topic) {
      setError('Por favor, informe um tema.');
      return;
    }

    setIsLoading(true);
    setError('');
    setGeneratedContent('');
    
    if (audioRef.current) {
        audioRef.current.pause();
        setIsSpeaking(false);
    }

    try {
      let specificInstructions = "";
      
      if (activityType === 'wordsearch') {
        const gridSize = difficulty === 'easy' ? '8x8' : difficulty === 'medium' ? '12x12' : '15x15';
        specificInstructions = `
          IMPORTANTE - FORMATO DE CAÇA-PALAVRAS:
          1. Gere uma grade de letras perfeitamente quadrada de tamanho ${gridSize}.
          2. A grade DEVE ser apresentada como linhas de letras maiúsculas separadas por UM espaço.
          3. Liste as palavras a serem encontradas ABAIXO da grade.
        `;
      } else if (activityType === 'match') {
        specificInstructions = `
          IMPORTANTE - FORMATO DE COLUNAS:
          1. Crie uma tabela Markdown (| Coluna A | Coluna B |) para o aluno ligar os itens.
          2. Coloque itens relacionados (mas desordenados se possível) nas colunas.
          3. Certifique-se de que a tabela tenha cabeçalhos claros.
        `;
      }

      const prompt = `
        Aja como um gerador de material didático direto.
        Crie uma folha de atividades para um aluno do 3º ano do Ensino Fundamental (8-9 anos).
        
        Tema: "${topic}"
        Detalhes do Conteúdo: "${lessonDetails}"
        Tipo: "${activityOptions.find(opt => opt.id === activityType)?.label}"
        Nível: ${difficultyOptions.find(d => d.id === difficulty)?.label}
        Instruções de formatação: ${customInstructions}
        ${specificInstructions}
        
        REGRAS DE ESTILO E TOM DE VOZ:
        1. Fale DIRETAMENTE com a criança (Use imperativo: "Faça", "Leia", "Ligue").
        2. Comece IMEDIATAMENTE com o Título da Atividade.
        
        REGRAS DE FORMATAÇÃO:
        1. Use Títulos com Markdown (# Título).
        2. Use **Negrito** para destacar palavras.
        3. Use listas com hífen (- item).
        4. Use Tabelas Markdown (| Item | Valor |) para atividades de relacionar.
        5. NÃO use LaTeX ou fórmulas com cifrão ($). Escreva frações como texto (ex: "1/3").
      `;

      const data = await fetchGemini('gemini-2.5-flash-preview-09-2025', {
        contents: [{ parts: [{ text: prompt }] }]
      });

      const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
      if (text) setGeneratedContent(text);
      else throw new Error('Sem resposta da IA.');

    } catch (err) {
      setError(`Erro: ${err.message}. Tente novamente em alguns instantes.`);
    } finally {
      setIsLoading(false);
    }
  };

  const handleCopy = () => {
    const cleanText = generatedContent
      .replace(/\*\*/g, '')
      .replace(/#/g, '')
      .trim();

    const textArea = document.createElement("textarea");
    textArea.value = cleanText;
    
    textArea.style.position = "fixed";
    textArea.style.left = "-9999px";
    textArea.style.top = "0";
    
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    
    try {
      const successful = document.execCommand('copy');
      if (successful) {
        alert('Texto copiado!');
      } else {
        throw new Error('Comando de cópia falhou');
      }
    } catch (err) {
      console.error('Falha ao copiar', err);
      alert('Não foi possível copiar automaticamente.');
    } finally {
      document.body.removeChild(textArea);
    }
  };

  const handlePrint = () => {
    window.print();
  };

  return (
    <div className="min-h-screen bg-slate-100 text-slate-800 font-sans print:bg-white">
      
