// --- Utilitários de Áudio (PCM para WAV) ---
const writeString = (view, offset, string) => {
  for (let i = 0; i < string.length; i++) {
    view.setUint8(offset + i, string.charCodeAt(i));
  }
};

const pcmToWav = (base64PCM, sampleRate = 24000) => {
  const binaryString = atob(base64PCM);
  const len = binaryString.length;
  const buffer = new ArrayBuffer(len);
  const view = new Uint8Array(buffer);
  for (let i = 0; i < len; i++) {
    view[i] = binaryString.charCodeAt(i);
  }
  
  const wavHeader = new ArrayBuffer(44);
  const headerView = new DataView(wavHeader);
  
  // RIFF identifier
  writeString(headerView, 0, 'RIFF');
  // RIFF chunk length
  headerView.setUint32(4, 36 + len, true);
  // WAVE identifier
  writeString(headerView, 8, 'WAVE');
  // fmt chunk identifier
  writeString(headerView, 12, 'fmt ');
  // fmt chunk length
  headerView.setUint32(16, 16, true);
  // Sample format (1 is PCM)
  headerView.setUint16(20, 1, true);
  // Channel count
  headerView.setUint16(22, 1, true);
  // Sample rate
  headerView.setUint32(24, sampleRate, true);
  // Byte rate (sampleRate * blockAlign)
  headerView.setUint32(28, sampleRate * 2, true);
  // Block align (channelCount * bytesPerSample)
  headerView.setUint16(32, 2, true);
  // Bits per sample
  headerView.setUint16(34, 16, true);
  // data chunk identifier
  writeString(headerView, 36, 'data');
  // data chunk length
  headerView.setUint32(40, len, true);

  const wavBlob = new Blob([headerView, view], { type: 'audio/wav' });
  return URL.createObjectURL(wavBlob);
};

// --- Componente de Renderização de Texto Rico ---
const RichTextRenderer = ({ content }) => {
  if (!content) return null;

  const renderInlineStyles = (text) => {
    // Remove qualquer formatação LaTeX residual que possa ter escapado ($...$)
    const cleanText = text.replace(/\$([^\$]+)\$/g, '$1'); 
    
    const parts = cleanText.split(/(\*\*.*?\*\*)/g);
    return parts.map((part, index) => {
      if (part.startsWith('**') && part.endsWith('**')) {
        return <strong key={index} className="text-blue-900 font-bold">{part.slice(2, -2)}</strong>;
      }
      return part;
    });
  };

  const lines = content.split('\n');
  const elements = [];
  let listBuffer = [];
  let gridBuffer = [];
  let tableBuffer = [];

  const flushList = () => {
    if (listBuffer.length > 0) {
      elements.push(
        <ul key={`list-${elements.length}`} className="list-disc pl-6 mb-4 space-y-2 text-slate-700">
          {listBuffer.map((item, i) => <li key={i} className="pl-1">{renderInlineStyles(item)}</li>)}
        </ul>
      );
      listBuffer = [];
    }
  };

  const flushGrid = () => {
    if (gridBuffer.length > 0) {
      const firstRowLetters = gridBuffer[0].trim().split(/\s+/);
      const cols = firstRowLetters.length;

      elements.push(
        <div key={`grid-${elements.length}`} className="my-8 flex justify-center no-break-inside">
          <div className="bg-white p-4 rounded-xl border-4 border-slate-800 shadow-lg inline-block print:border-2 print:shadow-none">
            <div 
              className="grid gap-1 md:gap-2" 
              style={{ gridTemplateColumns: `repeat(${cols}, minmax(1.5rem, 1fr))` }}
            >
              {gridBuffer.map((row, rowIndex) => {
                const letters = row.trim().split(/\s+/);
                return letters.map((letter, colIndex) => (
                  <div 
                    key={`${rowIndex}-${colIndex}`} 
                    className="w-8 h-8 md:w-10 md:h-10 flex items-center justify-center border border-slate-200 rounded md:rounded-lg font-mono text-lg md:text-xl font-bold text-slate-800 uppercase bg-slate-50 hover:bg-yellow-200 transition-colors print:border-slate-400 print:bg-white"
                  >
                    {letter}
                  </div>
                ));
              })}
            </div>
          </div>
        </div>
      );
      gridBuffer = [];
    }
  };

  const flushTable = () => {
    if (tableBuffer.length > 0) {
      // Filtra linhas de separação (ex: |---|---|)
      const rows = tableBuffer.filter(row => !row.includes('---'));
      
      if (rows.length > 0) {
        // Função auxiliar para limpar e dividir as células
        const parseRow = (rowStr) => {
          return rowStr
            .split('|')
            .filter((cell, index, arr) => {
              // Remove o primeiro e último elemento se forem vazios (comuns em tabelas markdown | a | b |)
              if ((index === 0 || index === arr.length - 1) && cell.trim() === '') return false;
              return true;
            })
            .map(cell => cell.trim());
        };

        const headers = parseRow(rows[0]);
        const bodyRows = rows.slice(1).map(parseRow);

        elements.push(
          <div key={`table-${elements.length}`} className="my-6 overflow-hidden rounded-xl border border-slate-300 shadow-sm print:shadow-none print:border-slate-400">
            <table className="w-full text-left border-collapse">
              <thead className="bg-blue-50 border-b border-blue-100 print:bg-slate-100">
                <tr>
                  {headers.map((h, i) => (
                    <th key={i} className="p-4 font-bold text-blue-900 text-sm uppercase tracking-wider print:text-black">
                      {renderInlineStyles(h)}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-200 print:divide-slate-300">
                {bodyRows.map((row, i) => (
                  <tr key={i} className="bg-white hover:bg-slate-50 transition-colors print:bg-white">
                    {row.map((cell, j) => (
                      <td key={j} className="p-4 text-slate-700 border-r last:border-r-0 border-slate-100 print:border-slate-300 print:text-black font-medium">
                        {renderInlineStyles(cell)}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      }
      tableBuffer = [];
    }
  };

  lines.forEach((line, index) => {
    const trimmedLine = line.trim();
    
    // Detecção de Tabela (começa com |)
    if (trimmedLine.startsWith('|')) {
      flushList();
      flushGrid();
      tableBuffer.push(trimmedLine);
      return;
    } else {
      flushTable();
    }

    // Detecção de Caça-Palavras
    const isGridRow = /^[A-Z]( +[A-Z]){2,}$/.test(trimmedLine);
    if (isGridRow) {
      flushList();
      flushTable(); // Garante que tabelas anteriores foram renderizadas
      gridBuffer.push(trimmedLine);
      return;
    } else {
      flushGrid();
    }

    // Detecção de Listas
    if (trimmedLine.startsWith('- ') || trimmedLine.startsWith('* ')) {
      listBuffer.push(trimmedLine.substring(2));
      return;
    } else {
      flushList();
    }

    // Títulos e Texto
    if (trimmedLine.startsWith('### ')) {
      elements.push(<h3 key={index} className="text-lg font-bold text-blue-600 mt-6 mb-2">{trimmedLine.slice(4)}</h3>);
    } else if (trimmedLine.startsWith('## ')) {
      elements.push(<h2 key={index} className="text-xl font-bold text-blue-700 mt-8 mb-3 pb-2 border-b border-blue-100">{trimmedLine.slice(3)}</h2>);
    } else if (trimmedLine.startsWith('# ')) {
      elements.push(<h1 key={index} className="text-2xl font-extrabold text-blue-800 mt-4 mb-4">{trimmedLine.slice(2)}</h1>);
    } else if (trimmedLine === '') {
      elements.push(<div key={index} className="h-2"></div>);
    } else {
      elements.push(
        <p key={index} className="mb-3 text-slate-700 leading-relaxed text-lg">
          {renderInlineStyles(line)}
        </p>
      );
    }
  });

  // Limpar buffers finais
  flushList();
  flushGrid();
  flushTable();

  return <div className="animate-fade-in">{elements}</div>;
};

export default function App() {
  const [apiKey, setApiKey] = useState('');
